{
  "includes": [
    "**/*.json",
    "**/*.md",
    "**/*.toml"
  ],
  "excludes": [
    "**/.DS_Store",
    ".git",
    ".idea",
    "AGENTS.md",
    "content/_index.md",
    "gallery",
    "public",
    "static/gallery",
    "static/processed_images",
    "TODO.md"
  ],
  "plugins": [
    "https://plugins.dprint.dev/json-0.22.0.wasm",
    "https://plugins.dprint.dev/markdown-0.22.1.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm"
  ]
}
